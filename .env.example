# ── AI Provider ──────────────────────────────────────────────────────────────
# When set, the real LLM API is used. When absent, the deterministic
# MockProvider runs end-to-end with no external dependencies.
LLM_API_KEY=

# ── Orchestrator gates ────────────────────────────────────────────────────────
# Minimum confidence score [0.00–1.00] required before auto-executing a
# refund or replacement action. Requests below this threshold are escalated.
CONFIDENCE_THRESHOLD=0.5

# Monetary ceiling for auto-refunds. Refund amounts above this limit are
# treated as high-risk and escalated regardless of confidence score.
REFUND_HIGH_VALUE_LIMIT=200.00

# ── Intent classification ─────────────────────────────────────────────────────
# Confidence floor for intent classification. Messages classified below this
# value are assigned the 'general_inquiry' intent instead of a specific one.
INTENT_CONFIDENCE_FLOOR=0.70

# ── RAG retrieval ─────────────────────────────────────────────────────────────
# Minimum TF-IDF cosine similarity score for a policy passage to be considered
# relevant. Passages scoring below this threshold are excluded from results.
RAG_RELEVANCE_THRESHOLD=0.05

# ── Agent Dashboard ───────────────────────────────────────────────────────────
# Polling interval in milliseconds for the agent dashboard. Clamped to the
# 3000–5000 ms range; values outside that range fall back to the default.
DASHBOARD_POLL_MS=4000
